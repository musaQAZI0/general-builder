# MongoDB Atlas (cloud) connection string.
# Get it from Atlas → Connect → Drivers. Include the DB name (general-builder).
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/general-builder?retryWrites=true&w=majority
# For a local MongoDB instead, use:
# MONGODB_URI=mongodb://127.0.0.1:27017/general-builder

NEXTAUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Gmail SMTP for password-reset + new-quote notification emails
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-google-app-password

# Optional: inbox that receives new-quote notifications.
# Defaults to uzairawan211@gmail.com if not set.
# OWNER_EMAIL=owner@example.com
