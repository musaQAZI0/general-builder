# MongoDB Atlas cloud connection string.
# Get it from Atlas -> Connect -> Drivers. Include the DB name: general-builder.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/general-builder?retryWrites=true&w=majority

# For local development only:
# MONGODB_URI=mongodb://127.0.0.1:27017/general-builder

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-production-secret

# Local: http://localhost:3000
# Vercel production: https://your-project.vercel.app or your custom domain, no trailing slash
NEXTAUTH_URL=http://localhost:3000

# Gmail SMTP for password reset, owner quote notifications, and customer confirmations.
# Use a Gmail App Password, not your normal Gmail password.
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-google-app-password

# Inbox that receives new quote notifications.
OWNER_EMAIL=owner@example.com

# Comma-separated admin emails that can open /admin.
# If omitted, OWNER_EMAIL is treated as admin.
ADMIN_EMAILS=owner@example.com
